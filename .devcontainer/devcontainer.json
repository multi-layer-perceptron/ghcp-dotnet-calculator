{
  "name": "GitHub Copilot .NET Calculator Labs",
  "image": "mcr.microsoft.com/devcontainers/dotnet:2-10.0-noble",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "username": "vscode"
    },
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "none",
      "dotnetRuntimeVersions": "8.0",
      "aspNetCoreRuntimeVersions": "8.0"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:4": {
      "version": "latest",
      "moby": true,
      "dockerDashComposeVersion": "v2",
      "installDockerBuildx": true
    },
    "ghcr.io/devcontainers/features/node:2": {
      "version": "22",
      "pnpmVersion": "none"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "os-provided",
      "installTools": false
    },
    "ghcr.io/devcontainers/features/powershell:2": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "version": "latest",
      "installBicep": true,
      "bicepVersion": "latest"
    },
    "ghcr.io/azure/azure-dev/azd:0": {},
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "1.15.6",
      "installTFsec": false,
      "installTerraformDocs": false
    }
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  "mounts": [
    "source=ghcp-dotnet-calculator-nuget,target=/home/vscode/.nuget/packages,type=volume",
    "source=ghcp-dotnet-calculator-npm,target=/home/vscode/.npm,type=volume",
    "source=ghcp-dotnet-calculator-playwright,target=/home/vscode/.cache/ms-playwright,type=volume",
    "source=ghcp-dotnet-calculator-docker,target=/var/lib/docker,type=volume"
  ],
  "forwardPorts": [
    5000
  ],
  "portsAttributes": {
    "5000": {
      "label": "Blazor calculator",
      "onAutoForward": "notify",
      "protocol": "http"
    }
  },
  "remoteEnv": {
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
    "DOTNET_NOLOGO": "1"
  },
  "remoteUser": "vscode",
  "postCreateCommand": "bash .devcontainer/scripts/post-create.sh",
  "waitFor": "postCreateCommand",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "git.autofetch": true,
        "files.exclude": {
          "**/bin": true,
          "**/obj": true,
          "src/completed": true
        },
        "files.watcherExclude": {
          "**/bin/**": true,
          "**/obj/**": true
        }
      },
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "GitHub.vscode-github-actions",
        "GitHub.vscode-pull-request-github",
        "DavidAnson.vscode-markdownlint",
        "HashiCorp.terraform",
        "ms-azuretools.vscode-azureresourcegroups",
        "ms-azuretools.vscode-bicep",
        "ms-azuretools.vscode-containers",
        "ms-dotnettools.csdevkit",
        "ms-playwright.playwright",
        "ms-vscode.azurecli",
        "ms-vscode.powershell",
        "redhat.vscode-yaml"
      ]
    }
  }
}