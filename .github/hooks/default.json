{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "./scripts/hooks/pre-tool-use-secret-scan.sh",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\hooks\\pre-tool-use-secret-scan.ps1",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "pwsh -NoProfile -File ./scripts/hooks/post-tool-use-dotnet-build.ps1",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\hooks\\post-tool-use-dotnet-build.ps1",
        "timeout": 30
      }
    ]
  }
}