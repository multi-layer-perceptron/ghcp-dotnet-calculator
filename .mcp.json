{
  "mcpServers": {
    "azureDevOps": {
      "type": "http",
      "url": "https://mcp.dev.azure.com/autocloudarc-mcaps",
      "tools": [
        "*"
      ]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "tools": [
        "*"
      ]
    },
    "microsoftLearn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp",
      "tools": [
        "*"
      ]
    },
    "playwright": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@1.52.0-alpha-2025-03-26",
        "--headless"
      ],
      "tools": [
        "*"
      ]
    },
    "memory": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_FILE_PATH": "${workspaceFolder}/.memory/memory.json"
      },
      "tools": [
        "*"
      ]
    }
  }
}